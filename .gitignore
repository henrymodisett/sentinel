# Secrets & config (NEVER commit these)
.env
.env.*
!.env.example
config.json
credentials.json
*.pem
*.key
*.p12

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp
*.swo
*~

# Dependencies
node_modules/
vendor/
__pycache__/
*.pyc
.venv/
venv/
.python-version

# Build output
dist/
build/
*.egg-info/
.next/
out/

# Build-time artifact written by hatch-vcs — version derived from git
# at build time. Never hand-edited, must not be committed.
src/sentinel/_version.py

# uv
uv.lock

# Touchstone
*.bak

# Sentinel dogfood artifacts (the sentinel repo runs sentinel on itself
# for testing — these are generated per-run and shouldn't be committed)
.sentinel/config.toml
.sentinel/goals.md
.sentinel/backlog.md
.sentinel/lenses.md
.sentinel/scans/
.sentinel/state/
.sentinel/proposals/
.sentinel/executions/
.sentinel/reviews/
.sentinel/runs/
.sentinel/worktrees/
.sentinel/domain_brief.md

# Test coverage
coverage/
